---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import data from '../data/data.json';

const studioSocials = data.studioSocials || [];
---

<Layout title="72bit Stüdyo">
  <Navbar />

  <main id="bg-container" class="relative w-full bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-50 transition-colors duration-500 overflow-hidden tracking-tight min-h-screen">
    
    {/* Arka Plan Etkileşimli Noktaları */}
    <canvas id="interactive-dots-canvas" class="absolute inset-0 w-full h-full pointer-events-none z-0 opacity-80"></canvas>

    <section class="relative z-20 pt-32 pb-10 px-4 sm:px-6 max-w-4xl mx-auto text-center md:text-left">
      <span class="text-[10px] sm:text-xs font-black tracking-[0.3em] uppercase text-zinc-400 dark:text-zinc-500 block mb-3">// GELECEĞİ BİRLİKTE INŞA EDELİM</span>
      <h1 class="text-3xl sm:text-5xl font-black tracking-tighter uppercase leading-none text-zinc-900 dark:text-white mb-6">
        72BIT’TE KARİYER
      </h1>
      
      <div class="space-y-4 text-xs sm:text-base text-zinc-600 dark:text-zinc-400 font-medium max-w-2xl leading-relaxed">
        <p>
          72bit'te hiyerarşiden uzak, tamamen üretim ve vizyon odaklı bir ekosistem kuruyoruz.
          Amacımız sadece oyun yapmak değil; oyuncunun zihninde kalıcı izler bırakacak yeni nesil dijital sanat eserleri üretmek.
        </p>
        <p>
          Eğer sen de sınırları zorlamayı seviyor, oyun mekaniklerine veya dijital sanata farklı bir perspektiften bakıyorsan, aşağıdaki form aracılığıyla bize ulaşabilirsin.
          Açık bir pozisyon olmasa bile yeteneğe her zaman kapımız açık.
        </p>
      </div>
    </section>

    <section class="relative z-20 pb-24 px-4 sm:px-6 max-w-4xl mx-auto">
      
      <h3 class="text-xs sm:text-sm font-black tracking-widest text-zinc-400 dark:text-zinc-500 uppercase mb-6 block">// GENEL BAŞVURU FORMU</h3>
      
      <form id="careers-form" novalidate class="space-y-5 sm:space-y-6">
        
        <div class="flex flex-col md:flex-row gap-5">
          
          <div class="w-full md:w-3/5 grid grid-cols-1 sm:grid-cols-2 gap-5">
            
            <div class="form-group bg-zinc-50/80 dark:bg-zinc-900/40 backdrop-blur-sm p-4 rounded-xl border border-zinc-200/80 dark:border-zinc-900 shadow-lg flex flex-col gap-2 justify-between transition-all duration-300">
              <label class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Adınız Soyadınız *</label>
              <input type="text" name="fullname" required class="w-full px-3 py-2.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-lg text-xs sm:text-sm font-medium focus:outline-none focus:border-zinc-400 dark:focus:border-zinc-600 transition shadow-sm" placeholder="John Doe" />
              <span class="error-msg text-[10px] text-red-500 font-bold tracking-wide uppercase hidden mt-1">// Bu alan boş bırakılamaz</span>
            </div>

            <div class="form-group bg-zinc-50/80 dark:bg-zinc-900/40 backdrop-blur-sm p-4 rounded-xl border border-zinc-200/80 dark:border-zinc-900 shadow-lg flex flex-col gap-2 justify-between transition-all duration-300">
              <label class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">E-Posta Adresiniz *</label>
              <input type="email" name="email" required class="w-full px-3 py-2.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-lg text-xs sm:text-sm font-medium focus:outline-none focus:border-zinc-400 dark:focus:border-zinc-600 transition shadow-sm" placeholder="johndoe@example.com" />
              <span class="error-msg text-[10px] text-red-500 font-bold tracking-wide uppercase hidden mt-1">// Geçerli bir e-posta girin</span>
            </div>

            <div class="form-group bg-zinc-50/80 dark:bg-zinc-900/40 backdrop-blur-sm p-4 rounded-xl border border-zinc-200/80 dark:border-zinc-900 shadow-lg flex flex-col gap-2 justify-between transition-all duration-300">
              <label class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Alanınız / Rolünüz *</label>
              <div class="relative w-full">
                <select name="role" required class="w-full px-3 py-2.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-lg text-xs sm:text-sm font-medium focus:outline-none focus:border-zinc-400 dark:focus:border-zinc-600 transition appearance-none text-zinc-700 dark:text-zinc-300 pr-8 shadow-sm">
                  <option value="" disabled selected>Bir alan seçin</option>
                  <option value="gameplay-dev">Gameplay Developer</option>
                  <option value="engine-dev">Engine / Graphics Developer</option>
                  <option value="3d-art">3D Artist / Animator</option>
                  <option value="ui-ux">UI / UX Designer</option>
                  <option value="game-design">Game Designer</option>
                  <option value="other">Diğer / Genel Yetenek</option>
                </select>
                <div class="absolute inset-y-0 right-2.5 flex items-center pointer-events-none text-zinc-400">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
              </div>
              <span class="error-msg text-[10px] text-red-500 font-bold tracking-wide uppercase hidden mt-1">// Lütfen bir rol seçin</span>
            </div>

            <div class="form-group bg-zinc-50/80 dark:bg-zinc-900/40 backdrop-blur-sm p-4 rounded-xl border border-zinc-200/80 dark:border-zinc-900 shadow-lg flex flex-col gap-2 justify-between transition-all duration-300">
              <label class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Portfolyo / GitHub Linki</label>
              <input type="url" name="portfolio" class="w-full px-3 py-2.5 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-lg text-xs sm:text-sm font-medium focus:outline-none focus:border-zinc-400 dark:focus:border-zinc-600 transition shadow-sm" placeholder="https://github.com/username" />
              <span class="error-msg text-[10px] text-red-500 font-bold tracking-wide uppercase hidden mt-1">// Geçerli bir URL adresi girin</span>
            </div>

          </div>

          <div class="form-group w-full md:w-2/5 bg-zinc-50/80 dark:bg-zinc-900/40 backdrop-blur-sm p-4 rounded-xl border border-zinc-200/80 dark:border-zinc-900 shadow-lg flex flex-col gap-2 transition-all duration-300">
            <label class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Özgeçmiş / CV (PDF) *</label>
            <div class="relative flex items-center justify-center w-full flex-grow">
              <label for="cv-upload" class="flex flex-col items-center justify-center w-full h-full min-h-[9rem] md:min-h-0 py-4 border-2 border-zinc-200 dark:border-zinc-800 border-dashed rounded-lg cursor-pointer bg-white dark:bg-zinc-950/40 hover:bg-zinc-100/50 dark:hover:bg-zinc-900/30 transition shadow-inner">
                <div id="upload-context" class="flex flex-col items-center justify-center text-center px-4">
                  <svg id="upload-icon" class="w-5 h-5 text-zinc-400 mb-2 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z"></path>
                  </svg>
                  <p id="upload-text" class="text-xs text-zinc-500 dark:text-zinc-400 leading-tight font-medium">
                    <span class="font-bold block text-[11px] sm:text-xs text-zinc-700 dark:text-zinc-300">Dosya seçin</span> 
                    <span class="hidden lg:inline text-[10px] text-zinc-400">veya sürükleyin</span>
                  </p>
                  <p id="upload-sub" class="text-[9px] text-zinc-400 dark:text-zinc-500 mt-0.5">PDF (Maks. 10MB)</p>
                </div>
                <input id="cv-upload" name="cvfile" type="file" accept=".pdf" required class="hidden" />
              </label>
            </div>
            <span class="error-msg text-[10px] text-red-500 font-bold tracking-wide uppercase hidden mt-1">// Lütfen CV dosyanızı yükleyin</span>
          </div>

        </div>

        <div class="form-group bg-zinc-50/80 dark:bg-zinc-900/40 backdrop-blur-sm p-4 rounded-xl border border-zinc-200/80 dark:border-zinc-900 shadow-lg flex flex-col gap-2 transition-all duration-300">
          <label class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Kendinizden Bahsedin (Özet) *</label>
          <textarea name="bio" required rows="4" class="w-full px-3 py-2 bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-lg text-xs sm:text-sm font-medium focus:outline-none focus:border-zinc-400 dark:focus:border-zinc-600 transition resize-none placeholder-zinc-400/80 shadow-sm" placeholder="Neler yapıyorsunuz, hangi teknolojileri veya sanat disiplinlerini benimsiyorsunuz?"></textarea>
          <span class="error-msg text-[10px] text-red-500 font-bold tracking-wide uppercase hidden mt-1">// Lütfen kısa bir özet yazın</span>
        </div>

        <div id="form-status-alert" class="hidden p-4 rounded-xl text-xs font-bold uppercase tracking-wider border transition-all duration-300"></div>

        <button type="submit" class="w-full py-3.5 sm:py-4 bg-zinc-900 dark:bg-zinc-800 hover:bg-zinc-800 dark:hover:bg-zinc-700 text-white font-bold text-xs tracking-wider uppercase rounded-xl transition shadow-lg hover:shadow-xl cursor-pointer">
          Başvuruyu Gönder
        </button>
      </form>
    </section>

  </main>
</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  // --- FORM KONTROLLERİ VE ÖZEL VALIDASYON TASARIMI ---
  const initFormLogic = () => {
    const form = document.getElementById('careers-form') as HTMLFormElement | null;
    const fileInput = document.getElementById('cv-upload') as HTMLInputElement | null;
    const uploadIcon = document.getElementById('upload-icon');
    const uploadText = document.getElementById('upload-text');
    const uploadSub = document.getElementById('upload-sub');

    if (!form) return;

    fileInput?.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (target.files && target.files.length > 0) {
        const file = target.files[0];
        if (uploadIcon && uploadText && uploadSub) {
          uploadIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`;
          uploadIcon.classList.remove('text-zinc-400', 'text-red-400');
          uploadIcon.classList.add('text-green-500');
          uploadText.innerHTML = `<span class="text-green-600 dark:text-green-400 font-bold block truncate max-w-[180px]">${file.name}</span>`;
          uploadSub.textContent = `${(file.size / (1024 * 1024)).toFixed(2)} MB Hazır`;
        }
        const group = fileInput.closest('.form-group');
        group?.classList.remove('border-red-500/50', 'dark:border-red-500/30', 'bg-red-50/10');
        group?.querySelector('.error-msg')?.classList.add('hidden');
      }
    });
    
    form.querySelectorAll('input, select, textarea').forEach((input) => {
      input.addEventListener('input', () => {
        const el = input as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
        if (el.checkValidity()) {
          const group = el.closest('.form-group');
          group?.classList.remove('border-red-500/50', 'dark:border-red-500/30', 'bg-red-50/10');
          group?.querySelector('.error-msg')?.classList.add('hidden');
        }
      });
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      let isFormValid = true;
      const statusAlert = document.getElementById('form-status-alert');

      form.querySelectorAll('input, select, textarea').forEach((input) => {
        const el = input as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
        const group = el.closest('.form-group');
        const errorMsg = group?.querySelector('.error-msg');

        if (!el.checkValidity()) {
          isFormValid = false;
          group?.classList.add('border-red-500/50', 'dark:border-red-500/30', 'bg-red-50/10');
          errorMsg?.classList.remove('hidden');
        } else {
          group?.classList.remove('border-red-500/50', 'dark:border-red-500/30', 'bg-red-50/10');
          errorMsg?.classList.add('hidden');
        }
      });

      if (statusAlert) {
        statusAlert.classList.remove('hidden', 'bg-red-50', 'dark:bg-red-950/20', 'text-red-600', 'border-red-500/30', 'bg-green-50', 'dark:bg-green-950/20', 'text-green-600', 'border-green-500/30');
        if (!isFormValid) {
          statusAlert.classList.add('bg-red-50', 'dark:bg-red-950/20', 'text-red-600', 'dark:text-red-400', 'border-red-500/30');
          statusAlert.innerHTML = `// BAŞVURU TAMAMLANAMADI. LÜTFEN KIRMIZI İŞARETLİ ALANLARI KONTROL EDİN.`;
        } else {
          statusAlert.classList.add('bg-green-50', 'dark:bg-green-950/20', 'text-green-600', 'dark:text-green-400', 'border-green-500/30');
          statusAlert.innerHTML = `// BAŞVURUNUZ BAŞARIYLA ALINDI. EKİBİMİZ SİZİNLE EN KISA SÜREDE İLETİŞİME GEÇECEKTİR.`;
          form.reset();
          if (uploadIcon && uploadText && uploadSub) {
            uploadIcon.classList.remove('text-green-500');
            uploadIcon.classList.add('text-zinc-400');
            uploadIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z"></path>`;
            uploadText.innerHTML = `<span class="font-bold block text-[11px] sm:text-xs text-zinc-700 dark:text-zinc-300">Dosya seçin</span><span class="hidden lg:inline text-[10px] text-zinc-400">veya sürükleyin</span>`;
            uploadSub.textContent = `PDF (Maks. 10MB)`;
          }
        }
      }
    });
  };
  
  // --- CANVAS ARKA PLAN NOKTALARI ---
  const canvas = document.getElementById('interactive-dots-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d');
    let dots: any[] = [];
    const mouse = { x: -1000, y: -1000, radius: 115 };
    const spacing = 28;

    class Dot {
      x: number; y: number; baseX: number; baseY: number;
      vx: number = 0; vy: number = 0;

      constructor(x: number, y: number) {
        this.x = x; this.y = y; this.baseX = x; this.baseY = y;
      }

      draw() {
        if (!ctx) return;
        
        ctx.fillStyle = document.documentElement.classList.contains('dark') 
          ? 'rgba(255, 255, 255, 0.1)' 
          : 'rgba(71, 85, 105, 0.35)';
        
        ctx.beginPath(); 
        const radius = document.documentElement.classList.contains('dark') ? 1.5 : 1.8;
        ctx.arc(this.x, this.y, radius, 0, Math.PI * 2);
        ctx.fill();
      }

      update() {
        let dx = mouse.x - this.x; let dy = mouse.y - this.y;
        let distance = Math.hypot(dx, dy);
        if (distance < mouse.radius && distance > 0) {
          let force = (mouse.radius - distance) / mouse.radius;
          this.vx -= (dx / distance) * force * 4.5; this.vy -= (dy / distance) * force * 4.5;
        }
        this.vx += (this.baseX - this.x) * 0.08; this.vy += (this.baseY - this.y) * 0.08;
        this.vx *= 0.85; this.vy *= 0.85;
        this.x += this.vx; this.y += this.vy;
      }
    }

    const init = () => {
      const parent = canvas.parentElement; if (!parent) return;
      canvas.width = parent.clientWidth; canvas.height = parent.clientHeight;
      dots = [];
      for (let x = spacing / 2; x < canvas.width; x += spacing) {
        for (let y = spacing / 2; y < canvas.height; y += spacing) {
          dots.push(new Dot(x, y));
        }
      }
    };

    window.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left; mouse.y = e.clientY - rect.top;
    });
    window.addEventListener('mouseleave', () => { mouse.x = -1000; mouse.y = -1000; });

    const animate = () => {
      if (!ctx) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < dots.length; i++) { dots[i].update(); dots[i].draw(); }
      requestAnimationFrame(animate);
    };

    init(); animate();
    window.addEventListener('resize', init);
    
    window.addEventListener('theme-changed', () => {
      setTimeout(init, 50);
    });
  }

  initFormLogic();
  document.addEventListener('astro:after-swap', initFormLogic);
</script>
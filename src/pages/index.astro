---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import data from '../data/data.json';

// Verilerin varlığından emin oluyoruz
const studioSocials = data?.studioSocials || [];
const gamesData = data?.games || [];
const teamData = data?.team || [];

// Ekip listesi boş değilse kayan yazı efekti (Marquee) için diziyi çoğaltıyoruz
const extendedTeam = teamData.length > 0 
  ? [...teamData, ...teamData, ...teamData, ...teamData] 
  : [];
---

<Layout title="72bit Stüdyo">
  <Navbar />

  <main 
    id="bg-container" 
    class="relative w-full bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-50 transition-colors duration-500 overflow-hidden tracking-tight"
    data-games={JSON.stringify(gamesData)}
  >
    
    {/* Arka Plan Etkileşimli Noktaları */}
    <canvas id="interactive-dots-canvas" class="absolute inset-0 w-full h-full pointer-events-none z-0 opacity-80"></canvas>

    {/* HERO SECTION */}
    <section class="relative h-screen w-full overflow-hidden flex flex-col justify-end items-start bg-black m-0 p-0 z-20 pb-16 sm:pb-24 px-6 md:px-12">
      <div class="absolute inset-0 w-full h-full z-0 pointer-events-none">
        <video autoplay loop muted playsinline class="w-full h-full object-cover opacity-60 dark:opacity-60">
          <source src="/videos/company-showreel.webm" type="video/webm" />
        </video>
        <div class="absolute inset-0 bg-gradient-to-tr from-zinc-950 via-zinc-950/45 to-transparent dark:from-zinc-950 dark:via-zinc-950/50 dark:to-transparent z-10"></div>
      </div>

      <div class="relative z-20 max-w-2xl text-left flex flex-col items-start">
        <span class="text-[9px] sm:text-xs font-black tracking-[0.3em] text-zinc-400 uppercase mb-3 block">// OYUNUN ÖTESİNDE, GELECEĞİN İÇİNDE</span>
        <h1 class="text-3xl xs:text-4xl sm:text-5xl md:text-6xl font-black tracking-tighter uppercase text-white leading-none mb-4 select-none filter drop-shadow-md break-words">
          YENİ NESİL <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-zinc-100 via-zinc-300 to-zinc-500 dark:from-white dark:via-zinc-400 dark:to-zinc-600">DİJİTAL DENEYİMLER</span>
        </h1>
        <p class="text-xs sm:text-sm font-medium text-zinc-300 dark:text-zinc-400 max-w-md leading-relaxed">
          72bit, sınırları zorlayan bağımsız oyunlar ve interaktif dünyalar inşa eden yaratıcı bir teknoloji ve sanat kolektifidir.
        </p>
      </div>
    </section>

    {/* HAKKIMIZDA (ABOUT) SECTION */}
    <section id="about" class="relative z-20 py-20 sm:py-32 px-4 sm:px-6 max-w-5xl mx-auto scroll-mt-12">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start">
        <div class="md:col-span-5">
          <span class="text-[10px] sm:text-xs font-black tracking-[0.3em] uppercase text-zinc-400 dark:text-zinc-500 block mb-2">// BİZ KİMİZ?</span>
          <h2 class="text-3xl sm:text-4xl font-black tracking-tighter uppercase text-zinc-900 dark:text-white leading-none">
            72BIT <br class="hidden md:inline" />STÜDYO HAKKINDA
          </h2>
        </div>
        <div class="md:col-span-7 flex flex-col gap-6">
          <p class="text-sm sm:text-base font-medium text-zinc-600 dark:text-zinc-300 leading-relaxed">
            Biz, geleneksel oyun kalıplarını kırmak ve oyunculara sadece birer "ürün" değil, akıllarında yer edecek derin ve sanatsal deneyimler sunmak amacıyla kurulmuş bağımsız bir geliştirici ekibiz. Teknoloji ile estetiğin kesiştiği noktada duruyor, her pikselde ve kod satırında tutkumuzu yansıtıyoruz.
          </p>
          <p class="text-xs sm:text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
            Modern araçları, dinamik hikaye anlatımını ve yenilikçi mekanikleri harmanlayarak küresel ölçekte projeler üretiyoruz. Bizim için oyun yapmak sadece yazılımdan ibaret değil; yeni dünyalar kurmanın en heyecan verici yolu.
          </p>
        </div>
      </div>
    </section>

    {/* GAMES SECTION */}
    <section id="games" class="relative z-20 py-20 sm:py-32 px-4 sm:px-6 max-w-5xl mx-auto border-t border-zinc-100 dark:border-zinc-900/60 scroll-mt-12">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
        <div>
          <span class="text-[10px] sm:text-xs font-black tracking-[0.3em] uppercase text-zinc-400 dark:text-zinc-500 block mb-2">// ÜRETİMLERİMİZ</span>
          <h2 class="text-3xl sm:text-4xl font-black tracking-tighter uppercase text-zinc-900 dark:text-white leading-none">GELİŞTİRİLEN PROJELER</h2>
        </div>
        {gamesData.length > 0 && (
          <p class="text-xs sm:text-sm font-medium text-zinc-500 dark:text-zinc-400 max-w-xs md:text-right">Kompakt listemizden projelerin kapaklarına tıklayarak tüm detaylara göz atabilirsiniz.</p>
        )}
      </div>

      {gamesData.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {gamesData.map((game, index) => {
            const primaryStoreLink = game.storeLinks && game.storeLinks.length > 0 ? game.storeLinks[0] : null;
            
            return (
              <div class="group relative z-20 flex flex-col sm:flex-row items-center sm:items-stretch bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 p-5 rounded-2xl transition-all duration-300 hover:shadow-xl hover:border-zinc-300 dark:hover:border-zinc-700 gap-4">
                
                <button 
                  class="open-modal-btn relative w-full sm:w-24 h-48 sm:h-32 rounded-xl overflow-hidden bg-zinc-950 shrink-0 cursor-zoom-in shadow-md group-hover:scale-[1.02] transition-transform duration-300"
                  data-index={index}
                >
                  <img 
                    src={game.coverImage || "/images/placeholder-cover.jpg"} 
                    alt={game.title || "Oyun Kapağı"} 
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" 
                    loading="lazy" 
                  />
                  <div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition-colors duration-300"></div>
                </button>

                <div class="flex flex-col justify-between items-center sm:items-start text-center sm:text-left flex-1 py-1 w-full">
                  <div class="w-full">
                    <div class="flex flex-wrap items-center justify-center sm:justify-start gap-2 mb-1">
                      <h3 class="text-base sm:text-lg font-black tracking-tight text-zinc-900 dark:text-white uppercase leading-tight">
                        {game.title || "İsimsiz Proje"}
                      </h3>
                      {game.version && (
                        <span class="text-[8px] font-bold font-mono text-zinc-400 dark:text-zinc-500 bg-zinc-100 dark:bg-zinc-800 px-1.5 py-0.2 rounded shrink-0">
                          {game.version}
                        </span>
                      )}
                    </div>
                    {game.genre && (
                      <p class="text-[10px] sm:text-xs font-bold text-red-500 uppercase tracking-wider mb-3">
                        {game.genre}
                      </p>
                    )}

                    <div class="w-full mt-1 mb-2 flex justify-center sm:justify-start">
                      {primaryStoreLink ? (
                        <a 
                          href={primaryStoreLink.url} 
                          target="_blank" 
                          rel="noopener noreferrer" 
                          class="inline-flex items-center justify-center px-4 py-1.5 text-[9px] font-black uppercase tracking-widest text-white rounded-lg transition-colors duration-200 shadow-sm select-none border bg-zinc-800 hover:bg-zinc-700 border-zinc-700"
                        >
                          {primaryStoreLink.platform === 'Steam' ? 'Steam\'de Oyna' : `${primaryStoreLink.platform}'da Oyna`}
                        </a>
                      ) : (
                        <span class="inline-block px-3 py-1 bg-zinc-100 dark:bg-zinc-800/60 text-zinc-400 dark:text-zinc-600 rounded-lg text-[9px] font-bold tracking-wider uppercase border border-transparent dark:border-zinc-800/40 select-none">
                          Yakında Mağazalarda
                        </span>
                      )}
                    </div>
                  </div>

                  <button 
                    class="open-modal-btn text-[11px] font-bold tracking-wider text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors uppercase flex items-center gap-1 mt-2"
                    data-index={index}
                  >
                    Detayları İncele →
                  </button>
                </div>

              </div>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-16 px-4 bg-zinc-50/60 dark:bg-zinc-900/40 border border-dashed border-zinc-200 dark:border-zinc-800/80 rounded-2xl backdrop-blur-sm relative z-20">
          <div class="w-12 h-12 rounded-full bg-white dark:bg-zinc-900 flex items-center justify-center mx-auto mb-4 border border-zinc-200/80 dark:border-zinc-800 shadow-sm">
            <svg class="w-6 h-6 text-zinc-400 dark:text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.656 48.656 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l-3 3m3-3l3 3" />
            </svg>
          </div>
          <h3 class="text-sm font-black uppercase tracking-wider text-zinc-900 dark:text-zinc-100 mb-1">PROJELER HAZIRLANIYOR</h3>
          <p class="text-[11px] font-medium text-zinc-500 dark:text-zinc-400 max-w-xs mx-auto">Geliştirme aşamasındaki heyecan verici projelerimiz çok yakında burada listelenecek.</p>
        </div>
      )}
    </section>

    {/* OYUN DETAY MODAL (LIGHTBOX) YAPISI */}
    <div id="game-modal" class="fixed inset-0 z-50 flex items-center justify-center p-3 sm:p-4 bg-zinc-950/80 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300">
      <div id="modal-content" class="relative w-full max-w-4xl bg-white dark:bg-zinc-900 rounded-3xl overflow-hidden border border-zinc-200/80 dark:border-zinc-800 shadow-2xl scale-95 transition-transform duration-300 max-h-[90vh] flex flex-col md:flex-row">
        
        <button id="close-modal-btn" class="absolute top-4 right-4 z-30 p-2 text-zinc-400 hover:text-zinc-950 dark:hover:text-white rounded-full bg-zinc-100/50 dark:bg-zinc-800/50 backdrop-blur transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>

        <div class="relative w-full md:w-80 h-44 sm:h-60 md:h-auto overflow-hidden bg-zinc-950 shrink-0">
          <img id="modal-cover" src="" alt="Oyun Kapağı" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-zinc-950/80 md:from-transparent to-transparent"></div>
        </div>

        <div class="flex-1 p-5 sm:p-8 flex flex-col justify-between overflow-y-auto no-scrollbar gap-6 max-h-[45vh] md:max-h-[80vh]">
          <div>
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <h3 id="modal-title" class="text-xl sm:text-3xl font-black tracking-tight text-zinc-900 dark:text-white uppercase leading-none"></h3>
              <span id="modal-version" class="text-[9px] font-bold font-mono text-zinc-400 dark:text-zinc-500 bg-zinc-100 dark:bg-zinc-800 px-2 py-0.5 rounded"></span>
            </div>

            <div class="flex flex-wrap gap-2 mb-4">
              <span id="modal-genre" class="px-2.5 py-0.5 bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 font-bold text-[10px] tracking-wider uppercase rounded"></span>
              <span id="modal-status" class="px-2.5 py-0.5 bg-zinc-900 text-white dark:bg-white dark:text-black font-black text-[10px] tracking-wider uppercase rounded"></span>
            </div>

            <p id="modal-description" class="text-zinc-600 dark:text-zinc-400 text-xs sm:text-sm font-medium leading-relaxed mb-6"></p>

            {/* İNDİRME LİNKLERİ */}
            <div id="modal-store-container" class="mb-6 hidden">
              <h4 class="text-[10px] font-black tracking-widest text-zinc-400 dark:text-zinc-500 uppercase mb-3">// MAĞAZALAR</h4>
              <div id="modal-store-links" class="flex flex-wrap gap-2 sm:gap-3"></div>
            </div>

            <div id="modal-screenshots-container">
              <h4 class="text-[10px] font-black tracking-widest text-zinc-400 dark:text-zinc-500 uppercase mb-3">// EKRAN GÖRÜNTÜLERİ</h4>
              <div id="modal-screenshots-grid" class="flex gap-3 overflow-x-auto pb-2 no-scrollbar"></div>
            </div>
          </div>
        </div>

      </div>
    </div>

    {/* EKRAN GÖRÜNTÜSÜ DETAY PENCERESİ */}
    <div id="image-lightbox" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/90 opacity-0 pointer-events-none transition-all duration-300 p-4 sm:p-8 cursor-zoom-out">
      <button id="close-lightbox-btn" class="absolute top-6 right-6 p-2 text-white/70 hover:text-white bg-white/10 rounded-full transition-all hover:scale-105 z-50">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
      <div class="relative max-w-5xl max-h-[85vh] flex items-center justify-center pointer-events-none">
        <img id="lightbox-img" src="" alt="Tam Ekran Görsel" class="max-w-full max-h-full object-contain rounded-2xl scale-95 transition-transform duration-300 shadow-2xl" />
      </div>
    </div>

    {/* TEAM SECTION */}
    {teamData.length > 0 && (
      <section id="team" class="relative z-20 py-20 sm:py-24 border-t border-zinc-100 dark:border-zinc-900/60 bg-zinc-50/50 dark:bg-zinc-900/10 overflow-hidden">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 mb-10 flex flex-col sm:flex-row justify-between items-center sm:items-end gap-6 text-center sm:text-left">
          <div>
            <span class="text-[10px] sm:text-xs font-black tracking-[0.3em] uppercase text-zinc-400 dark:text-zinc-500 block mb-2">// VİZYONERLER</span>
            <h2 class="text-3xl sm:text-5xl font-black tracking-tighter uppercase text-zinc-900 dark:text-white leading-none">ÇEKİRDEK EKİP</h2>
          </div>
          <a 
            href="/careers" 
            class="px-5 py-2.5 bg-zinc-950 dark:bg-white text-white dark:text-black font-bold text-[10px] sm:text-xs tracking-wider uppercase rounded-xl hover:bg-zinc-800 dark:hover:bg-zinc-200 transition-all shadow-md shrink-0 border border-transparent dark:border-zinc-200"
          >
            Ekibe Katıl
          </a>
        </div>

        <div class="relative w-full flex overflow-x-hidden group-marquee mask-gradient">
          <div class="animate-marquee flex gap-4 sm:gap-6 whitespace-nowrap py-4 pr-4 sm:pr-6">
            {extendedTeam.map((member, index) => (
              <div key={`member-${member.nickname || index}-${index}`} class="relative z-20 inline-flex flex-col w-[260px] sm:w-[320px] bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl p-5 sm:p-6 shadow-sm hover:shadow-md transition-all duration-300 select-none whitespace-normal justify-between">
                <div>
                  <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
                    <img src={member.avatar || `https://api.dicebear.com/9.x/bottts/svg?seed=${member.nickname || index}`} alt={member.name || "Ekip Üyesi"} class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl object-cover bg-zinc-100 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-800" loading="lazy" />
                    <div>
                      <h4 class="text-xs sm:text-base font-black tracking-tight text-zinc-900 dark:text-white">{member.name || "Anonim Geliştirici"}</h4>
                      <p class="text-[10px] sm:text-[11px] font-bold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider">{member.role || "Geliştirici"}</p>
                    </div>
                  </div>
                  {member.quote && (
                    <p class="text-[11px] sm:text-xs font-medium text-zinc-500 dark:text-zinc-400 italic leading-relaxed mb-4">"{member.quote}"</p>
                  )}
                </div>

                {member.socials && member.socials.length > 0 && (
                  <div class="flex gap-2 pt-2 border-t border-zinc-100 dark:border-zinc-800/60 mt-auto">
                    {member.socials.map((social) => (
                      <a href={social.url} target="_blank" rel="noopener noreferrer" class="text-[10px] font-bold px-2 py-1 bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white rounded transition-colors uppercase tracking-tight">
                        {social.platform}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* COMMUNITY SECTION */}
    <section class="relative z-20 py-20 sm:py-32 px-4 sm:px-6 max-w-4xl mx-auto text-center">
      <span class="text-[10px] sm:text-xs font-black tracking-[0.3em] uppercase text-zinc-400 dark:text-zinc-500 block mb-3">// TOPLULUK</span>
      <h2 class="text-3xl sm:text-6xl font-black tracking-tighter uppercase text-zinc-900 dark:text-white leading-none mb-6">BİZE KATILIN</h2>
      <p class="text-xs sm:text-base font-medium text-zinc-500 dark:text-zinc-400 max-w-xl mx-auto leading-relaxed mb-10">
        Geliştirme süreçlerimizi yakından takip etmek, alfa testlerine katılmak ve ekiple doğrudan iletişim kurmak için topluluğumuza dahil olun.
      </p>
      {studioSocials.length > 0 && (
        <div class="flex flex-wrap justify-center gap-3 sm:gap-4 mb-10">
          {studioSocials.map((social) => (
            <a href={social.url} target="_blank" rel="noopener noreferrer" class="px-5 py-3 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-zinc-800 dark:text-zinc-200 font-bold text-xs tracking-wider uppercase rounded-xl hover:bg-zinc-100 dark:hover:bg-zinc-800 transition shadow-sm relative z-20">
              {social.platform}
            </a>
          ))}
        </div>
      )}
    </section>

  </main>
</Layout>

<style>
  .animate-marquee {
    display: flex;
    width: max-content;
    animation: marquee 25s linear infinite;
  }
  .group-marquee:hover .animate-marquee {
    animation-play-state: paused;
  }
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-50%); }
  }
  .mask-gradient {
    mask-image: linear-gradient(to right, transparent, white 8%, white 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, white 8%, white 92%, transparent);
  }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const mainContainer = document.getElementById('bg-container');
  const modal = document.getElementById('game-modal');
  const modalContent = document.getElementById('modal-content');
  const closeModalBtn = document.getElementById('close-modal-btn');
  
  const modalCover = document.getElementById('modal-cover') as HTMLImageElement | null;
  const modalTitle = document.getElementById('modal-title');
  const modalVersion = document.getElementById('modal-version');
  const modalGenre = document.getElementById('modal-genre');
  const modalStatus = document.getElementById('modal-status');
  const modalDescription = document.getElementById('modal-description');
  const modalScreenshotsGrid = document.getElementById('modal-screenshots-grid');
  
  const modalStoreContainer = document.getElementById('modal-store-container');
  const modalStoreLinks = document.getElementById('modal-store-links');

  const lightbox = document.getElementById('image-lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const closeLightboxBtn = document.getElementById('close-lightbox-btn');

  let gamesData: any[] = [];
  if (mainContainer) {
    try {
      gamesData = JSON.parse(mainContainer.getAttribute('data-games') || '[]');
    } catch (err) {
      console.error("Oyun verisi ayrıştırılamadı:", err);
    }
  }

  const openModal = (index: number) => {
    const game = gamesData[index];
    if (!game) return;

    if (modalCover) {
      modalCover.src = game.coverImage || "/images/placeholder-cover.jpg";
      modalCover.alt = game.title || "Oyun Kapağı";
    }
    if (modalTitle) modalTitle.textContent = game.title || "İsimsiz Proje";
    if (modalVersion) modalVersion.textContent = game.version || "";
    if (modalGenre) modalGenre.textContent = game.genre || "";
    if (modalStatus) modalStatus.textContent = game.status || "";
    if (modalDescription) modalDescription.textContent = game.description || "Bu oyun için henüz bir açıklama eklenmedi.";

    // Mağaza Butonları
    if (modalStoreLinks && modalStoreContainer) {
      modalStoreLinks.innerHTML = '';
      if (game.storeLinks && game.storeLinks.length > 0) {
        modalStoreContainer.classList.remove('hidden');
        game.storeLinks.forEach((link: any) => {
          if (link && link.url && link.platform) {
            const btn = document.createElement('a');
            btn.href = link.url;
            btn.target = '_blank';
            btn.rel = 'noopener noreferrer';
            
            btn.innerHTML = `<span class="font-black tracking-widest text-white">${link.platform === 'Steam' ? 'Steam\'de Oyna' : `${link.platform}'da Oyna`}</span>`;
            btn.className = "inline-flex items-center justify-center px-6 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-white rounded-xl text-[10px] sm:text-[11px] uppercase transition-colors duration-200 shadow-sm border border-zinc-700 select-none";
            
            modalStoreLinks.appendChild(btn);
          }
        });
      } else {
        modalStoreContainer.classList.add('hidden');
      }
    }

    // Ekran Görüntüleri
    if (modalScreenshotsGrid) {
      modalScreenshotsGrid.innerHTML = '';
      const screenshotsContainer = document.getElementById('modal-screenshots-container');
      
      if (game.screenshots && game.screenshots.length > 0) {
        screenshotsContainer?.classList.remove('hidden');
        game.screenshots.forEach((imgUrl: string, i: number) => {
          const wrapper = document.createElement('button');
          wrapper.className = 'relative w-28 h-16 sm:w-36 sm:h-20 rounded-xl overflow-hidden border border-zinc-200 dark:border-zinc-800 shrink-0 cursor-zoom-in hover:border-zinc-400 transition-colors shadow-sm';
          
          const img = document.createElement('img');
          img.src = imgUrl;
          img.alt = `${game.title || "Oyun"} Görsel ${i + 1}`;
          img.className = 'w-full h-full object-cover hover:scale-105 transition-transform duration-300';
          img.loading = 'lazy';

          wrapper.appendChild(img);

          wrapper.addEventListener('click', () => {
            if (lightboxImg && lightbox) {
              lightboxImg.src = imgUrl;
              lightboxImg.alt = img.alt;
              lightbox.classList.remove('opacity-0', 'pointer-events-none');
              setTimeout(() => {
                lightboxImg.classList.remove('scale-95');
              }, 50);
            }
          });

          modalScreenshotsGrid.appendChild(wrapper);
        });
      } else {
        screenshotsContainer?.classList.add('hidden');
      }
    }

    if (modal && modalContent) {
      modal.classList.remove('opacity-0', 'pointer-events-none');
      setTimeout(() => {
        modalContent.classList.remove('scale-95');
      }, 50);
    }

    document.body.style.overflow = 'hidden';
  };

  const closeModal = () => {
    if (modal && modalContent) {
      modalContent.classList.add('scale-95');
      modal.classList.add('opacity-0', 'pointer-events-none');
    }
    document.body.style.overflow = '';
  };

  const closeLightbox = () => {
    if (lightboxImg && lightbox) {
      lightboxImg.classList.add('scale-95');
      lightbox.classList.add('opacity-0', 'pointer-events-none');
    }
  };

  document.querySelectorAll('.open-modal-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLElement;
      const isAnchor = (e.target as HTMLElement).closest('a');
      if (isAnchor) return;

      const index = parseInt(target.getAttribute('data-index') || '0', 10);
      openModal(index);
    });
  });

  closeModalBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  closeLightboxBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target === lightboxImg?.parentElement) closeLightbox();
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (lightbox && !lightbox.classList.contains('opacity-0')) {
        closeLightbox();
      } else {
        closeModal();
      }
    }
  });
</script>

<script>
  const canvas = document.getElementById('interactive-dots-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d');
    let dots: any[] = [];
    const mouse = { x: -1000, y: -1000, radius: 115 };
    const spacing = 28;

    class Dot {
      x: number; y: number; baseX: number; baseY: number;
      vx: number = 0; vy: number = 0;

      constructor(x: number, y: number) {
        this.x = x; this.y = y; this.baseX = x; this.baseY = y;
      }

      draw() {
        if (!ctx) return;
        
        ctx.fillStyle = document.documentElement.classList.contains('dark') 
          ? 'rgba(255, 255, 255, 0.1)' 
          : 'rgba(71, 85, 105, 0.35)';
        
        ctx.beginPath(); 
        const radius = document.documentElement.classList.contains('dark') ? 1.5 : 1.8;
        ctx.arc(this.x, this.y, radius, 0, Math.PI * 2);
        ctx.fill();
      }

      update() {
        let dx = mouse.x - this.x; let dy = mouse.y - this.y;
        let distance = Math.hypot(dx, dy);
        if (distance < mouse.radius && distance > 0) {
          let force = (mouse.radius - distance) / mouse.radius;
          this.vx -= (dx / distance) * force * 4.5; this.vy -= (dy / distance) * force * 4.5;
        }
        this.vx += (this.baseX - this.x) * 0.08; this.vy += (this.baseY - this.y) * 0.08;
        this.vx *= 0.85; this.vy *= 0.85;
        this.x += this.vx; this.y += this.vy;
      }
    }

    const init = () => {
      const parent = canvas.parentElement; if (!parent) return;
      canvas.width = parent.clientWidth; canvas.height = parent.clientHeight;
      dots = [];
      for (let x = spacing / 2; x < canvas.width; x += spacing) {
        for (let y = spacing / 2; y < canvas.height; y += spacing) {
          dots.push(new Dot(x, y));
        }
      }
    };

    window.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left; mouse.y = e.clientY - rect.top;
    });
    window.addEventListener('mouseleave', () => { mouse.x = -1000; mouse.y = -1000; });

    const animate = () => {
      if (!ctx) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = 0; i < dots.length; i++) { dots[i].update(); dots[i].draw(); }
      requestAnimationFrame(animate);
    };

    init(); animate();
    window.addEventListener('resize', init);
    
    window.addEventListener('theme-changed', () => {
      setTimeout(init, 50);
    });
  }
</script>
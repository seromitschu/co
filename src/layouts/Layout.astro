---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="tr">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Oyun Stüdyosu Resmi Web Sitesi" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
		
			if (theme === 'light') {
				document.documentElement.classList.remove('dark');
			} else {
				document.documentElement.classList.add('dark');
			}
		</script>
	</head>
	<body class="bg-white dark:bg-black text-zinc-900 dark:text-white transition-colors duration-500 antialiased m-0 p-0">
		
		<div id="premium-scroll-track">
			<div id="premium-scroll-thumb"></div>
		</div>

		<slot />

		<script>
			const initLayoutLogic = () => {
				// 1. Tema Yönetimi
				const currentTheme = localStorage.getItem('theme') || 
					(window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				
				if (currentTheme === 'light') {
					document.documentElement.classList.remove('dark');
				} else {
					document.documentElement.classList.add('dark');
				}

				// 2. Momentum & Esneme Tabanlı Scroll Mekanizması
				const track = document.getElementById('premium-scroll-track');
				const thumb = document.getElementById('premium-scroll-thumb');
				
				let lastScrollY = window.scrollY;
				let scrollTimeout;

				if (track && thumb) {
					const updateScroll = () => {
						const scrollTop = window.scrollY;
						const docHeight = document.documentElement.scrollHeight - window.innerHeight;
						
						if (docHeight <= 0) return;

						// Kaydırma oranı (%)
						const scrollPercent = (scrollTop / docHeight) * 100;
						
						const trackHeight = track.clientHeight;
						const thumbHeight = thumb.clientHeight;
						const maxTop = trackHeight - thumbHeight;
						const currentTop = (scrollPercent / 100) * maxTop;

						// Anlık scroll hızını hesapla (Esneme efekti için)
						const deltaY = Math.abs(scrollTop - lastScrollY);
						// Maksimum 1.5 katına kadar dikeyde esneme payı veriyoruz
						const scaleY = Math.min(1 + deltaY * 0.015, 1.5); 
						
						lastScrollY = scrollTop;

						// Çubuğu hem hareket ettiriyoruz hem de hızına göre esnetiyoruz
						thumb.style.transform = `translateY(${currentTop}px) scaleY(${scaleY})`;

						// Aktiflik sınıfını ekle (Pürüzsüzce parlayarak belirecek)
						track.classList.add('is-active');

						// Hareket bittiğinde yumuşatılmış sönme zamanlayıcısı
						clearTimeout(scrollTimeout);
						scrollTimeout = setTimeout(() => {
							track.classList.remove('is-active');
							thumb.style.transform = `translateY(${currentTop}px) scaleY(1)`; // Esnemeyi sıfırla
						}, 800); // 800ms sonra pürüzsüzce kaybolur
					};

					window.removeEventListener('scroll', updateScroll);
					window.addEventListener('scroll', updateScroll, { passive: true });
					updateScroll();
				}
			};

			initLayoutLogic();
			document.addEventListener('astro:after-swap', initLayoutLogic);
		</script>
	</body>
</html>

<style is:global>
	/* Standart tarayıcı çubuklarını temizle */
	html {
		scrollbar-width: none;
	}
	html::-webkit-scrollbar {
		display: none;
	}

	/* PREMIUM TRACK ALANI */
	#premium-scroll-track {
		position: fixed;
		top: 0;
		right: 0;
		width: 5px; /* Minimalist incelik */
		height: 100vh;
		z-index: 9999;
		background: transparent;
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.5s cubic-bezier(0.25, 1, 0.5, 1);
	}

	#premium-scroll-track.is-active {
		opacity: 1;
	}

	/* ESNEYEN ŞEFFAF KAPSÜL */
	#premium-scroll-thumb {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 65px; /* Şık kısa kapsül */
		border-radius: 99px;
		transition: transform 0.15s cubic-bezier(0.25, 1, 0.5, 1);
		will-change: transform;
		
		/* Light Mod: Şeffaf koyu zinc tonu */
		background: rgba(24, 24, 27, 0.35);
		box-shadow: 0 2px 8px rgba(24, 24, 27, 0.08);
	}

	/* DARK MOD: Şeffaf soft beyaz buzlu cam tonu */
	html.dark #premium-scroll-thumb {
		background: rgba(255, 255, 255, 0.25);
		/* Aşırı parlama yerine çok soft, göz yormayan şeffaf bir süzülme etkisi */
		box-shadow: 0 2px 10px rgba(255, 255, 255, 0.08);
	}
</style>
<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const setupNavbar = () => {
    const navbar = document.getElementById('main-navbar');
    const logo = document.getElementById('navbar-logo');
    const menu = document.getElementById('navbar-menu');
    const toggleBtn = document.getElementById('theme-toggle');

    const handleScroll = () => {
      if (window.scrollY > 40) {
        navbar?.classList.remove('py-4', 'bg-transparent');
        navbar?.classList.add('py-3', 'bg-white/60', 'dark:bg-black/60', 'backdrop-blur-md', 'shadow-sm');

        logo?.classList.add('border-transparent');
        logo?.classList.remove('border-zinc-200', 'dark:border-zinc-800/80');

        menu?.classList.add('border-transparent');
        menu?.classList.remove('border-zinc-200', 'dark:border-zinc-800/80');

        toggleBtn?.classList.add('border-transparent');
        toggleBtn?.classList.remove('border-zinc-200', 'dark:border-zinc-800/80');
      } else {
        navbar?.classList.remove('py-3', 'bg-white/60', 'dark:bg-black/60', 'backdrop-blur-md', 'shadow-sm');
        navbar?.classList.add('py-4', 'bg-transparent');

        logo?.classList.remove('border-transparent');
        logo?.classList.add('border-zinc-200', 'dark:border-zinc-800/80');

        menu?.classList.remove('border-transparent');
        menu?.classList.add('border-zinc-200', 'dark:border-zinc-800/80');

        toggleBtn?.classList.remove('border-transparent');
        toggleBtn?.classList.add('border-zinc-200', 'dark:border-zinc-800/80');
      }
    };

    // Scroll dinleyicisini temizleyip tekrar ekliyoruz
    window.removeEventListener('scroll', handleScroll);
    window.addEventListener('scroll', handleScroll);
    handleScroll(); // İlk durum kontrolü

    // Çift click tetiklenmesini önlemek için eski dinleyiciyi temizleyip yenisini tanımlıyoruz
    if (toggleBtn) {
      const toggleTheme = () => {
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          document.documentElement.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
        // Custom event yayınlayarak sayfadaki diğer bileşenlerin (Canvas gibi) anlık haberdar olmasını sağlıyoruz
        window.dispatchEvent(new Event('theme-changed'));
      };

      // Eski referansları klonlayarak event dinleyicilerini sıfırlıyoruz
      const newToggleBtn = toggleBtn.cloneNode(true);
      toggleBtn.parentNode?.replaceChild(newToggleBtn, toggleBtn);
      newToggleBtn.addEventListener('click', toggleTheme);
    }
  };

  setupNavbar();
  document.addEventListener('astro:after-swap', setupNavbar);
</script>